# Interface definition for thorn TriggerX

IMPLEMENTS: TriggerX
INHERITS: CarpetXRegrid

USES INCLUDE HEADER: tuple.hxx
USES INCLUDE HEADER: loop.hxx
USES INCLUDE HEADER: reduction.hxx

PUBLIC:

CCTK_REAL TriggerX_Vars DISTRIB=CONSTANT TAGS='checkpoint="no"'
{
  trigger_cctk_iteration
  trigger_cctk_time
} "Auxiliary scalars that can be used in trigger conditions"
